# =============================================================
# Africa Tourism Intelligence Platform — Backend Environment
# =============================================================
# Copy this file to .env and fill in your real values.
# Never commit your actual .env file to source control!

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=8080
ENVIRONMENT=development    # Options: development, production

# ── PostgreSQL ────────────────────────────────────────────────
# Local Dev:   postgresql://postgres:password@localhost:5432/africa_tourism?sslmode=disable
# Docker:      postgresql://postgres:password@tourism-db:5432/africa_tourism?sslmode=disable
DATABASE_URL=postgresql://postgres:password@localhost:5432/africa_tourism?sslmode=disable

# ── Auth ──────────────────────────────────────────────────────
# REQUIRED — must be a strong random secret (minimum 32 characters)
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-chars

# ── Redis ─────────────────────────────────────────────────────
# Used for: JWT blacklisting (logout), AI result caching, rate limiting
# Local Dev:  redis://localhost:6379
# Docker:     redis://tourism-redis:6379
REDIS_URL=redis://localhost:6379

# ── Google Gemini AI ──────────────────────────────────────────
# Used for AI-powered itinerary generation
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SEC=120

# ── Cloudinary Storage ────────────────────────────────────────
# Used for image and video uploads (posts, packages, avatars)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Get your credentials at: https://cloudinary.com/console
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Email (Brevo / Sendinblue) ────────────────────────────────
# Used for email verification and password reset emails
# Get your key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Africa Tourism Platform

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── Frontend ──────────────────────────────────────────────────
# Base URL of the frontend app — used for email verification and password-reset redirect links
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
