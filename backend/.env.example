# 🌍 Africa Tourism Platform - Backend Environment
# ================================================

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=8080
ENVIRONMENT=development # Options: development, production

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/africa_tourism?sslmode=disable

# ── Auth ─────────────────────────────────────────────────────
# REQUIRED — must be a strong random secret (min 32 characters)
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-chars

# ── Redis ────────────────────────────────────────────────────
# Shared across instances for distributed rate limiting & caching
REDIS_URL=redis://localhost:6379

# ── Google Gemini AI ─────────────────────────────────────────
# Used for AI itinerary generation
GEMINI_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-flash-latest

# ── Cloudinary ───────────────────────────────────────────────
# Used for image and video uploads
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
